library(knitr)
library(gtsummary)
library(gt)
library(dplyr)
library(ggplot2)
data <- read.csv("~/Desktop/country_data.csv", header=TRUE)
subset_data <- data %>%
select(name, region, gdp, life_expectancy_male, life_expectancy_female,
unemployment, homicide_rate, iso2, capital, gdp_growth,
population, pop_density, gdp_per_capita, co2_emissions, tourists) %>%
na.omit() %>%
mutate(region_group = case_when(
# Americas
region %in% c("South America", "Central America", "Northern America", "Caribbean") ~ "Americas",
# Europe
region %in% c("Southern Europe", "Western Europe", "Eastern Europe", "Northern Europe") ~ "Europe",
# Asia
region %in% c("Southern Asia", "Western Asia", "South-Eastern Asia", "Eastern Asia", "Central Asia") ~ "Asia",
# Africa
region %in% c("Northern Africa", "Middle Africa", "Western Africa", "Southern Africa", "Eastern Africa") ~ "Africa",
# Oceania
region %in% c("Oceania", "Melanesia", "Micronesia", "Polynesia") ~ "Oceania",
# Default
TRUE ~ region
))
table_one <- subset_data %>%
select(gdp, life_expectancy_male, life_expectancy_female, unemployment, population, pop_density, gdp_per_capita, co2_emissions, region_group, region, name) %>%
tbl_summary(by = region_group,
label = list(
gdp ~ "Total GDP",
life_expectancy_male ~ "Male Life Expectancy",
life_expectancy_female ~ "Female Life Expectancy",
unemployment ~ "Unemployment Rate (%)",
population ~ "Total Population",
pop_density ~ "Population Density",
gdp_per_capita ~ "GDP per Capita",
co2_emissions ~ "CO2 Emissions")) %>%
add_overall()
table_one
region_Africa <- subset_data %>%
filter(region_group == "Africa")
ggplot(region_Africa, aes(x = reorder(name, +population), y = population)) +
geom_col(fill = "steelblue") +
coord_flip() +
theme_minimal() +
labs(
title = "Population across Africa",
subtitle = paste("Analysis of", nrow(region_Africa), "countries"),
x = "Country",
y = "Population"
)
region_Africa <- subset_data %>%
filter(region_group == "Africa")
ggplot(region_Africa, aes(x = reorder(name, +population), y = population)) +
